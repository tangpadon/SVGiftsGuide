<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FAF3E0"> <TextView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="Stardew Valley Gift Guide"
    android:textSize="24sp"
    android:textStyle="bold"
    android:textColor="#5D4037"
    android:layout_marginBottom="16dp"
    android:gravity="center" />

    <AutoCompleteTextView
        android:id="@+id/autoCompleteItem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="พิมพ์ชื่อไอเทม เช่น Amethyst"
        android:padding="12dp"
        android:background="@android:drawable/editbox_background" />

    <Button
        android:id="@+id/btnCheck"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ตรวจสอบความชอบ NPC"
        android:layout_marginTop="12dp"
        android:backgroundTint="#8D6E63" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💜 Love (NPC รักมาก)"
                android:textColor="#D81B60"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/txtLoveResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ยังไม่มีข้อมูล"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="😊 Like (NPC ชอบ)"
                android:textColor="#388E3C"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/txtLikeResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ยังไม่มีข้อมูล" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>